# ============================================
# CreatorPulse Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# === Supabase (required) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# === Server ===
PORT=4000
NODE_ENV=development

# === Encryption (required) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here

# === AI Service (required from Phase 2+) ===
# AI_SERVICE_URL=http://localhost:8000
# AI_SERVICE_KEY=your-shared-secret

# === LinkedIn OAuth (required from Phase 3+) ===
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=http://localhost:4000/api/linkedin/callback
